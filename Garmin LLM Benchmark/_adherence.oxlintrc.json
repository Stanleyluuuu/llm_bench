{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "exports/**",
              "handoff/reference/**",
              "ui_kits/benchmark/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Inter, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|dot|pill|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, variant, dot, pill."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:success|warning|error|pending|builtin|custom|score-high|score-mid|score-low|grounding|ocr|detection|vlm|default)$/]",
        "message": "<Badge> variant must be one of 'success' | 'warning' | 'error' | 'pending' | 'builtin' | 'custom' | 'score-high' | 'score-mid' | 'score-low' | 'grounding' | 'ocr' | 'detection' | 'vlm' | 'default'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|disabled|loading|onClick|type|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, disabled, loading, onClick, type, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|outline|ghost|destructive)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'outline' | 'ghost' | 'destructive'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|unit|status|loading|trend|key|ref|className|style|children)$/]",
        "message": "<MetricCard> doesn't accept that prop. Declared props: label, value, unit, status, loading, trend."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricCard'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:normal|warning|error|active)$/]",
        "message": "<MetricCard> status must be one of 'normal' | 'warning' | 'error' | 'active'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ModelChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|name|kind|enabled|modelType|onToggle|accentColor|details|key|ref|className|style|children)$/]",
        "message": "<ModelChip> doesn't accept that prop. Declared props: label, name, kind, enabled, modelType, onToggle, accentColor, details."
      },
      {
        "selector": "JSXOpeningElement[name.name='ModelChip'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:builtin|custom)$/]",
        "message": "<ModelChip> kind must be one of 'builtin' | 'custom'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ModelChip'] > JSXAttribute[name.name='modelType'] > Literal[value!=/^(?:LLM|VLM)$/]",
        "message": "<ModelChip> modelType must be one of 'LLM' | 'VLM'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Progress'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|max|variant|height|animated|key|ref|className|style|children)$/]",
        "message": "<Progress> doesn't accept that prop. Declared props: value, max, variant, height, animated."
      },
      {
        "selector": "JSXOpeningElement[name.name='Progress'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|success|warning|destructive|score-high|score-mid|score-low)$/]",
        "message": "<Progress> variant must be one of 'default' | 'success' | 'warning' | 'destructive' | 'score-high' | 'score-mid' | 'score-low'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
